# =============================================================================
#  LAMD Project — Environment Variable Template
#
#  HOW TO USE:
#    1. Copy this file and rename the copy to  .env  (no extension suffix):
#         copy .env.example .env       (Windows CMD)
#         cp .env.example .env         (Mac/Linux)
#
#    2. Open .env and replace the placeholder with your real API key.
#
#    3. NEVER commit .env to git. It is already listed in .gitignore.
#       Only commit this .env.example file (it has no real secrets).
#
#  WHERE TO GET THE API KEY:
#    Register for free at https://androzoo.uni.lu/
#    After approval you will receive your personal API key by email.
# =============================================================================

# Your AndroZoo API key — paste the real value in your local .env copy.
ANDROZOO_API_KEY=your_androzoo_api_key_here
